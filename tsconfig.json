{
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["es2023"],

    "strict": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "verbatimModuleSyntax": true,

    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "noEmit": true,
    "isolatedModules": true,

    "types": ["node"]
  },
  // test/ tsc routing: this (server) config checks all test/**/*.ts EXCEPT
  // test/e2e/**/*.spec.ts, test/e2e/coverage-fixtures.ts, and test/admin/**
  // (DOM-dependent → tsconfig.e2e.json, which has the dom lib).
  // tsconfig.browser.json is emit-only and checks no tests.
  // A new test/<dir>/ defaults here (no-DOM); add it to tsconfig.e2e.json
  // if it uses DOM/Playwright types.
  "include": ["src/**/*.ts", "test/**/*.ts", "test/e2e/server-runner.ts", "bin/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "src/admin/**", "src/site/**", "static/**", "test/e2e/**/*.spec.ts", "test/e2e/coverage-fixtures.ts", "test/admin/**"]
}
