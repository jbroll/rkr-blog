{
  "name": "rkr-blog",
  "version": "0.1.0",
  "description": "Single-author CMS with photo-first content model.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "site-admin": "./bin/site-admin"
  },
  "scripts": {
    "start": "node --no-warnings=ExperimentalWarning --experimental-strip-types bin/server.js",
    "test": "node --test --no-warnings=ExperimentalWarning --experimental-strip-types 'test/**/*.test.ts'",
    "test:coverage": "c8 --include='src/**/*.ts' --exclude='src/admin/**' --exclude='**/*.test.ts' --reporter=text --check-coverage --per-file --lines=90 --branches=75 --functions=90 -- node --no-warnings=ExperimentalWarning --experimental-strip-types --test 'test/**/*.test.ts'",
    "test:coverage:report": "c8 --include='src/**/*.ts' --exclude='src/admin/**' --exclude='**/*.test.ts' --reporter=text --reporter=text-summary -- node --no-warnings=ExperimentalWarning --experimental-strip-types --test 'test/**/*.test.ts'",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.browser.json --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "knip": "knip",
    "knip:gate": "knip --no-progress",
    "circular": "dpdm --circular --no-warning --no-tree --exit-code circular:1 'src/**/*.ts'",
    "test:e2e": "playwright test --config test/playwright.config.ts",
    "test:e2e:headed": "playwright test --config test/playwright.config.ts --headed",
    "test:e2e:ios": "set -a; [ -f secrets.env ] && . ./secrets.env; set +a; playwright test --config test/playwright.config.ios.ts",
    "test:coverage:full": "rm -rf coverage && npm run --silent test:coverage:report && npm run --silent build:admin && npm run --silent build:site && npm run --silent test:e2e",
    "format": "biome format --write",
    "check": "npm run typecheck && biome check && npm run test:coverage",
    "build:admin": "rm -rf static/admin && esbuild src/admin/main.ts src/admin/posts-list.ts src/admin/settings-page.ts --bundle --splitting --format=esm --target=es2022 --outdir=static/admin --entry-names=[name] --minify --sourcemap && esbuild src/admin/opfs-worker.ts --bundle --format=esm --target=es2022 --outdir=static/admin --entry-names=[name] --minify --sourcemap",
    "build:site": "rm -rf static/site && esbuild src/site/lightbox.ts src/site/carousel.ts src/site/img-retry.ts src/site/copy-link.ts src/site/comment-form.ts src/site/sw-unregister.ts src/site/sw-admin.ts src/site/sw-admin-register.ts --bundle --splitting --format=esm --target=es2022 --outdir=static/site --sourcemap --minify",
    "build": "npm run build:admin && npm run build:site",
    "clean:admin": "rm -rf static/admin",
    "clean:site": "rm -rf static/site",
    "setup": "bash scripts/setup.sh",
    "hooks:install": "git config core.hooksPath .githooks",
    "migrate": "node --no-warnings=ExperimentalWarning --experimental-strip-types bin/site-admin migrate",
    "render": "node --no-warnings=ExperimentalWarning --experimental-strip-types bin/site-admin render",
    "gc": "node --no-warnings=ExperimentalWarning --experimental-strip-types bin/site-admin gc"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.1",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "arctic": "^3.7.0",
    "fastify": "^5.0.0",
    "ipaddr.js": "^2.4.0",
    "jose": "^6.2.3",
    "mdast-util-directive": "^3.0.0",
    "nodemailer": "^6.10.1",
    "photoswipe": "^5.4.4",
    "rehype-parse": "^9.0.1",
    "remark": "^15.0.0",
    "remark-directive": "^3.0.0",
    "remark-frontmatter": "^5.0.0",
    "sharp": "^0.33.0",
    "unified": "^11.0.5",
    "yaml": "^2.5.0"
  },
  "knip": {
    "entry": [
      "src/cli/init.ts",
      "src/cli/migrate.ts",
      "src/cli/render.ts",
      "src/cli/gc.ts",
      "src/cli/server.ts",
      "src/cli/user.ts",
      "src/cli/import-wp.ts",
      "src/cli/reset.ts",
      "src/cli/jobs.ts",
      "src/cli/fix-wp-dates.ts",
      "src/admin/opfs-worker.ts",
      "src/admin/posts-list.ts",
      "src/admin/settings-page.ts",
      "src/site/carousel.ts",
      "src/site/copy-link.ts",
      "src/site/comment-form.ts",
      "src/site/img-retry.ts",
      "src/site/sw-unregister.ts",
      "src/site/sw-admin.ts",
      "src/site/sw-admin-register.ts",
      "scripts/check-bundle-size.ts",
      "scripts/check-duplicate-types.ts",
      "scripts/check-no-reexports.ts",
      "scripts/check-e2e-coverage.ts",
      "scripts/check-orientation.mjs",
      "test/**/*.test.ts",
      "test/e2e/**/*.spec.ts",
      "test/playwright.config.ts",
      "test/playwright.config.ios.ts",
      "bin/site-admin",
      "src/lib/comments.ts"
    ],
    "ignore": [
      "src/admin/css.d.ts",
      "src/site/css.d.ts",
      ".claude/**",
      ".claire/**"
    ],
    "ignoreDependencies": [
      "typescript-language-server"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@playwright/test": "^1.59.1",
    "@tiptap/core": "^3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^6.4.23",
    "browserstack-local": "^1.5.13",
    "c8": "^11.0.0",
    "cropperjs": "^1.6.2",
    "dpdm": "^4.0.1",
    "esbuild": "^0.28.0",
    "knip": "^6.12.1",
    "monocart-coverage-reports": "^2.12.11",
    "typescript": "^6.0.3",
    "typescript-language-server": "^4.4.1"
  }
}
