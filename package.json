{
  "name": "rkroll-cms",
  "version": "0.1.0",
  "description": "Single-author CMS with photo-first content model.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "site-admin": "./bin/site-admin"
  },
  "scripts": {
    "start": "node --no-warnings=ExperimentalWarning --experimental-strip-types bin/server.js",
    "test": "node --test --no-warnings=ExperimentalWarning --experimental-strip-types",
    "test:coverage": "c8 --include='src/**/*.ts' --exclude='src/admin/**' --exclude='**/*.test.ts' --reporter=text --check-coverage --per-file --lines=90 --branches=75 --functions=90 -- node --no-warnings=ExperimentalWarning --experimental-strip-types --test",
    "test:coverage:report": "c8 --include='src/**/*.ts' --exclude='src/admin/**' --exclude='**/*.test.ts' --reporter=text --reporter=text-summary -- node --no-warnings=ExperimentalWarning --experimental-strip-types --test",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.browser.json --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "check": "npm run typecheck && biome check && npm run test:coverage",
    "build:admin": "esbuild src/admin/main.ts --bundle --format=esm --target=es2022 --outfile=static/admin/main.js --minify --sourcemap",
    "build:site": "esbuild src/site/lightbox.ts src/site/carousel.ts --format=esm --target=es2022 --outdir=static/site --sourcemap",
    "build": "npm run build:admin && npm run build:site",
    "clean:admin": "rm -rf static/admin",
    "hooks:install": "git config core.hooksPath .githooks",
    "migrate": "node --no-warnings=ExperimentalWarning --experimental-strip-types bin/site-admin migrate",
    "render": "node --no-warnings=ExperimentalWarning --experimental-strip-types bin/site-admin render",
    "gc": "node --no-warnings=ExperimentalWarning --experimental-strip-types bin/site-admin gc"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.1",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "arctic": "^3.7.0",
    "argon2": "^0.40.0",
    "fastify": "^5.0.0",
    "ipaddr.js": "^2.4.0",
    "jose": "^6.2.3",
    "remark": "^15.0.0",
    "remark-directive": "^3.0.0",
    "remark-frontmatter": "^5.0.0",
    "sharp": "^0.33.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@tiptap/core": "^3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@types/node": "^25.6.0",
    "c8": "^11.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "typescript-language-server": "^4.4.1"
  }
}
