# secrets.env — secrets-only runtime configuration for rkr-blog.
#
# Non-secret config (SITE_ROOT, PUBLIC_BASE_URL, SPAM_*, SMTP_PORT…) lives
# in config.env (committed to git). This file holds only secrets.
#
# Instructions:
#   cp deploy/secrets.env.example secrets.env
#   # fill in values below
#   deploy.sh init .   # syncs to /etc/rkr-blog.env on first deploy
#
# secrets.env is gitignored. Never commit it.

# Google OAuth app credentials (https://console.cloud.google.com/apis/credentials).
# Authorised redirect URI: https://rkr-blog.rkroll.com/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Bearer token for the /admin API. Generate with: openssl rand -hex 32
ADMIN_TOKEN=

# Token for the Ollama proxy (see config.env for OLLAMA_BASE_URL).
OLLAMA_TOKEN=

# SMTP credentials for comment email notifications (optional).
# SMTP_PORT and other non-secret SMTP settings live in config.env.
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
NOTIFY_TO=
