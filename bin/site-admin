#!/usr/bin/env -S node --no-warnings=ExperimentalWarning --experimental-strip-types
// site-admin — top-level CLI dispatcher.
//
// Usage:
//   site-admin init
//   site-admin migrate
//   site-admin render [--post <slug>] [--since <iso>] [--force] [--concurrency N]
//   site-admin gc
//   site-admin verify
//   site-admin server [--port 3000]
//
// Future subcommands (see spec §16): reindex, import, password.

const COMMANDS = {
  init:    () => import('../src/cli/init.ts'),
  migrate: () => import('../src/cli/migrate.ts'),
  render:  () => import('../src/cli/render.ts'),
  gc:      () => import('../src/cli/gc.ts'),
  verify:  () => import('../src/cli/verify.ts'),
  server:  () => import('../src/cli/server.ts')
};

const KNOWN = Object.keys(COMMANDS);

function usage() {
  console.error(`usage: site-admin <command> [args...]
commands: ${KNOWN.join(', ')}`);
}

async function main() {
  const [cmd, ...rest] = process.argv.slice(2);
  if (!cmd) { usage(); process.exit(2); }

  const loader = COMMANDS[cmd];
  if (!loader) {
    console.error(`unknown command: ${cmd}`);
    usage();
    process.exit(2);
  }

  const mod = await loader();
  await mod.default(rest);
}

main().catch((err) => {
  console.error(err.stack || err.message || err);
  process.exit(1);
});
