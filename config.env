# Non-secret runtime configuration for rkr-blog.
# Committed to git — do not put secrets here.
# Secrets (GOOGLE_CLIENT_*, ADMIN_TOKEN, OLLAMA_TOKEN, SMTP_PASS, etc.)
# live in secrets.env (gitignored). Both files are merged into
# /etc/rkr-blog.env on deploy; secrets win on any collision.

SITE_ROOT=/var/www/rkr-blog
PUBLIC_BASE_URL=https://rkr-blog.rkroll.com

OLLAMA_BASE_URL=https://symon.rkroll.com:554/ollama
SPAM_MODEL=llama3.2:3b
SPAM_TIMEOUT_MS=8000
SPAM_MAX_ATTEMPTS=3

SMTP_PORT=587
