#!/usr/bin/env bash
# Tracked pre-commit hook. Enable with: npm run hooks:install
# (which sets `git config core.hooksPath .githooks`).
#
# Runs:
#   1. biome check on staged JS files (formatting + lint).
#   2. tsc --noEmit type check.
#   3. duplicate-type / no-reexports / knip / circular-import / size guards.
#   4. test suite under c8 with strict coverage thresholds.
#
# Failures abort the commit. To bypass deliberately, use `git commit --no-verify`.

set -euo pipefail

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

# Collect staged files Biome / tsc care about.
staged=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|js|json)$' || true)

if [ -n "$staged" ]; then
  echo "==> biome check (staged)"
  npx --no-install biome check --staged --no-errors-on-unmatched
fi

# tsc step is wired in when the first .ts file lands; until then it errors
# with TS18003 "No inputs were found". The migration commit re-enables it.
#
# Both tsconfigs run: server (tsconfig.json — covers src/{lib,routes,
# templates,widgets,cli,site}, test/, scripts/) AND browser (tsconfig.
# browser.json — covers src/admin/**). The browser config used to be
# checked only by `npm run typecheck`; not having it in the hook let an
# editor-only type bug slip through (commit d8a9d89). DEFERRED.md ⇒
# "Pre-commit hook only runs server tsc" tracks the history.
if compgen -G "src/**/*.ts" > /dev/null || compgen -G "test/**/*.ts" > /dev/null; then
  echo "==> tsc --noEmit (server)"
  npx --no-install tsc --noEmit
  echo "==> tsc --noEmit (browser)"
  npx --no-install tsc -p tsconfig.browser.json --noEmit
fi

# Cross-file duplicate type/interface/enum names. Biome and tsc don't catch
# this (TS scopes duplicate names per-module). The script below maintains
# an explicit allowlist for known-existing dupes (warn-on-existing pattern,
# same as the size hook); new dupes fail the commit.
if compgen -G "src/**/*.ts" > /dev/null; then
  echo "==> duplicate-type check"
  node --no-warnings=ExperimentalWarning --experimental-strip-types \
    scripts/check-duplicate-types.ts
fi

# No re-exports. We control all callers; `export { x } from './y'` is just
# a way to hide where x actually lives. Forces direct-import discipline.
if compgen -G "src/**/*.ts" > /dev/null; then
  echo "==> no-reexports check"
  node --no-warnings=ExperimentalWarning --experimental-strip-types \
    scripts/check-no-reexports.ts
fi

# Knip: full dead-code report — unused files / dependencies / exports
# / exported types / unlisted deps. The codebase landed at zero
# findings in 17cd1fa; new dead exports fail the commit.
echo "==> knip:gate"
npm run --silent knip:gate

# dpdm: catch circular import chains. tsc and biome don't flag these;
# circular imports cause subtle runtime issues (undefined imports, broken
# initialization order) that compile fine.
echo "==> circular-import check"
npm run --silent circular

# Per-file 500-line size limit.
#
# Policy:
#   * ANY production source file > 500 lines: FAIL.
#
# Applies to production source only (src/, bin/). Tests (test/) are exempt:
# test files legitimately grow with feature coverage, and forcing splits
# for size reasons fragments the failure-pinpoint experience without
# improving production code health.
#
# Pre-2026-05-09 the gate ran in warn-on-existing mode while main.ts was
# above the cap; once the admin-SPA splits brought every staged source
# file under 500, the warn branch was promoted to FAIL.
echo "==> 500-line size check"
size_limit=500
size_failures=0
staged_src=$(git diff --cached --name-only --diff-filter=ACM \
  | grep -E '^(src|bin)/.*\.(ts|js)$' || true)

for f in $staged_src; do
  staged_lines=$(git show ":$f" | wc -l | tr -d ' ')
  if [ "$staged_lines" -le "$size_limit" ]; then
    continue
  fi
  echo "  FAIL  $f: $staged_lines lines (limit $size_limit)"
  size_failures=$((size_failures + 1))
done

if [ "$size_failures" -gt 0 ]; then
  echo "size check failed: $size_failures file(s) over $size_limit lines."
  echo "split the file into smaller modules, or use --no-verify if you have explicit reason."
  exit 1
fi

# Test suite under c8 — strict per-file thresholds (lines=90 / branches=75 /
# functions=90, see package.json#test:coverage). Adds ~2-3s vs npm test
# alone; trade-off accepted to keep coverage from silently regressing.
echo "==> npm test:coverage"
npm run --silent test:coverage > /dev/null

echo "==> precommit OK"
